{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fblln/apexline/schemas/lap-diagnostics-event.schema.json",
  "title": "Apexline lap diagnostics event",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_kind",
    "provenance",
    "year",
    "session_type",
    "round",
    "event_name",
    "circuit_id",
    "circuit_name",
    "total_laps",
    "fitted_laps",
    "compliant_laps",
    "non_compliant_laps",
    "shape_non_compliant_laps",
    "reason_counts",
    "thresholds"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_kind": {"const": "lap_diagnostics_event"},
    "year": {"type": "integer"},
    "session_type": {"type": "string"},
    "round": {"type": "integer"},
    "event_name": {"type": "string"},
    "circuit_id": {"type": "string"},
    "circuit_name": {"type": "string"},
    "total_laps": {"type": "integer"},
    "fitted_laps": {"type": "integer"},
    "compliant_laps": {"type": "integer"},
    "non_compliant_laps": {"type": "integer"},
    "shape_non_compliant_laps": {"type": "integer"},
    "reason_counts": {"type": "object"},
    "thresholds": {
      "type": "object",
      "required": [
        "length_tolerance_pct",
        "rmse_threshold_m",
        "p95_threshold_m",
        "rmse_threshold_pct_of_length",
        "p95_threshold_pct_of_length",
        "reference_length_m",
        "effective_rmse_threshold_m",
        "effective_p95_threshold_m"
      ],
      "properties": {
        "length_tolerance_pct": {"type": "number"},
        "rmse_threshold_m": {"type": "number"},
        "p95_threshold_m": {"type": "number"},
        "rmse_threshold_pct_of_length": {"type": "number"},
        "p95_threshold_pct_of_length": {"type": "number"},
        "reference_length_m": {"type": "number"},
        "effective_rmse_threshold_m": {"type": "number"},
        "effective_p95_threshold_m": {"type": "number"}
      }
    },
    "provenance": {"type": "object"}
  }
}
